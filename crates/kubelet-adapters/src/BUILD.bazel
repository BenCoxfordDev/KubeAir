load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# Read the Kubernetes version from .version and expose it as KUBERNETES_VERSION
# for env!("KUBERNETES_VERSION") in Rust source.
genrule(
    name = "kubernetes_version_env",
    srcs = ["//:version"],
    outs = ["kubernetes_version.env"],
    cmd = "echo KUBERNETES_VERSION=$$(cat $<) | tr -d '[:space:]' | sed 's/KUBERNETES_VERSION=/KUBERNETES_VERSION=/' > $@",
)

