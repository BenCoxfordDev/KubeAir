build --test_output=errors
test --test_output=errors
build --incompatible_strict_action_env

# clippy checks
build --aspects=@rules_rust//rust:defs.bzl%rust_clippy_aspect
build --output_groups=+clippy_checks
build --@rules_rust//rust/settings:clippy.toml=//:clippy.toml

# rustfmt
build --@rules_rust//rust/settings:rustfmt.toml=//:rustfmt.toml
build --aspects=@rules_rust//rust:defs.bzl%rustfmt_aspect
build --output_groups=+rustfmt_checks

# Configuration for building without clippy checks
build:no_clippy --output_groups=-clippy_checks

# hermetic_cc_toolchain: allow zig to write its cache
build:linux --sandbox_add_mount_pair=/tmp
build:macos --sandbox_add_mount_pair=/var/tmp

# On macOS, cap parallelism to reduce peak memory pressure.
# jemalloc's C compilation (tikv-jemalloc-sys) is killed by the OOM
# killer when too many Bazel sandbox processes run concurrently.
build:macos --jobs=8
build:macos --local_ram_resources=HOST_RAM*0.6

# Inside the e2e podman container. Size to the VM's available RAM —
# currently 8GB, so allow 6GB to Bazel and run 6 parallel jobs.
build:container --jobs=6
build:container --local_resources=ram=6144
build:container --local_resources=cpu=6
